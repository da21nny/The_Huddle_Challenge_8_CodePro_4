<!-- Incluye el header con head, navbar y apertura del main -->
<%- include('../partials/header.ejs') %>

    <h1>Temas de Aprendizaje</h1>

    <!-- Formulario para crear un nuevo topic -->
    <h2>Crear Tema</h2>
    <form action="/topics" method="POST">
        <input type="text" name="title" placeholder="Título del tema" required>
        <input type="text" name="description" placeholder="Descripción del tema" required>
        <button type="submit">Crear</button>
    </form>

    <!-- Lista de todos los topics existentes -->
    <h2>Lista de Temas</h2>
    <ul>
        <!-- Itera sobre cada topic y renderiza su tarjeta -->
        <% topics.forEach(topic=> { %>
            <li class="topic" data-votes="<%= topic.votes %>">
                <!-- Enlace al detalle del topic -->
                <a href="/topics/<%= topic.id %>">
                    <strong>
                        <%= topic.title %>
                    </strong>
                </a>
                <p>
                    <%= topic.description %>
                </p>

                <!-- Contador de votos y botón para votar (AJAX) -->
                <span id="topic-votes-<%= topic.id %>">Votos: <%= topic.votes %></span>
                <button class="vote-topic-btn" data-id="<%= topic.id %>">👍 Votar</button>

                <!-- Botón de editar -->
                <a href="/topics/<%= topic.id %>/edit">✏️ Editar</a>

                <!-- Formulario de eliminar: envía DELETE mediante method-override -->
                <form action="/topics/<%= topic.id %>?_method=DELETE" method="POST" style="display:inline;">
                    <button type="submit">🗑️ Eliminar</button>
                </form>
            </li>
            <% }) %>
    </ul>

    <!-- Incluye el footer con cierre del main y scripts -->
    <%- include('../partials/footer.ejs') %>