
    <h1>Temas de Aprendizaje</h1>

    <h2>Crear Tema</h2>
    <form action="/topics" method="POST">
        <input type="text" name="title" placeholder="Título del tema" required>
        <input type="text" name="description" placeholder="Descripción del tema" required>
        <button type="submit">Crear</button>
    </form>

    <h2>Lista de Temas</h2>
    <ul>
        {{#each topics}}
            <li class="topic" data-votes="{{ this.votes }}">
                <a href="/topics/{{ this.id }}">
                    <strong>
                        {{ this.title }}
                    </strong>
                </a>
                <p>
                    {{ this.description }}
                </p>

                <span id="topic-votes-{{ this.id }}">Votos: {{ this.votes }}</span>
                <button class="vote-topic-btn" data-id="{{ this.id }}">👍 Votar</button>

                <a href="/topics/{{ this.id }}/edit">✏️ Editar</a>

                <form action="/topics/{{ this.id }}?_method=DELETE" method="POST" style="display:inline;">
                    <button type="submit">🗑️ Eliminar</button>
                </form>
            </li>
        {{/each}}
    </ul>
