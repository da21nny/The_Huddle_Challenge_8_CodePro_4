<!-- Incluye el header con head, navbar y apertura del main -->
<%- include('../partials/header.ejs') %>

    <!-- Enlace para volver a la lista de topics -->
    <a href="/topics">← Volver a Temas</a>

    <!-- Detalle del topic: título y descripción -->
    <h1>
        <%= topic.title %>
    </h1>
    <p>
        <%= topic.description %>
    </p>

    <!-- Contador de votos y botón para votar el topic -->
    <span id="topic-votes-<%= topic.id %>">Votos: <%= topic.votes %></span>
    <button class="vote-topic-btn" data-id="<%= topic.id %>">👍 Votar</button>

    <!-- Enlace para editar este topic -->
    <a href="/topics/<%= topic.id %>/edit">✏️ Editar Tema</a>

    <!-- Formulario de eliminar topic: envía DELETE mediante method-override -->
    <form action="/topics/<%= topic.id %>?_method=DELETE" method="POST" style="display:inline;">
        <button type="submit">🗑️ Eliminar Tema</button>
    </form>

    <hr>

    <!-- Formulario para agregar un nuevo enlace al topic -->
    <h2>Agregar Enlace</h2>
    <form action="/topics/<%= topic.id %>/links" method="POST">
        <input type="text" name="title" placeholder="Título del enlace" required>
        <input type="text" name="url" placeholder="URL del enlace" required>
        <button type="submit">Agregar</button>
    </form>

    <!-- Lista de enlaces asociados al topic -->
    <h2>Enlaces</h2>
    <ul>
        <!-- Itera sobre cada enlace y renderiza su tarjeta -->
        <% links.forEach(link=> { %>
            <li class="link" data-votes="<%= link.votes %>">
                <!-- Enlace externo: abre en nueva pestaña -->
                <a href="<%= link.url %>" target="_blank">
                    <strong>
                        <%= link.title %>
                    </strong>
                </a>
                <!-- Contador de votos y botón para votar el enlace -->
                <span id="vote-count-<%= link.id %>">Votos: <%= link.votes %></span>
                <button class="vote-link-btn" data-id="<%= link.id %>" data-topic-id="<%= topic.id %>">👍 Votar</button>

                <!-- Enlace para editar este enlace -->
                <a href="/topics/<%= topic.id %>/links/<%= link.id %>/edit">✏️ Editar</a>

                <!-- Formulario de eliminar enlace: envía DELETE mediante method-override -->
                <form action="/topics/<%= topic.id %>/links/<%= link.id %>?_method=DELETE" method="POST"
                    style="display:inline;">
                    <button type="submit">🗑️ Eliminar</button>
                </form>
            </li>
            <% }) %>
    </ul>

    <!-- Incluye el footer con cierre del main y scripts -->
    <%- include('../partials/footer.ejs') %>