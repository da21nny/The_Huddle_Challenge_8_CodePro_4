<%- include('../partials/header.ejs') %>

    <a href="/topics">← Volver a Temas</a>

    <h1>
        <%= topic.title %>
    </h1>
    <p>
        <%= topic.description %>
    </p>

    <!-- Votar por este tema -->
    <span id="topic-votes-<%= topic.id %>">Votos: <%= topic.votes %></span>
    <button class="vote-topic-btn" data-id="<%= topic.id %>">👍 Votar</button>

    <!-- Editar este tema -->
    <a href="/topics/<%= topic.id %>/edit">✏️ Editar Tema</a>

    <!-- Eliminar este tema -->
    <form action="/topics/<%= topic.id %>?_method=DELETE" method="POST" style="display:inline;">
        <button type="submit">🗑️ Eliminar Tema</button>
    </form>

    <hr>

    <!-- Formulario para agregar un enlace -->
    <h2>Agregar Enlace</h2>
    <form action="/topics/<%= topic.id %>/links" method="POST">
        <input type="text" name="title" placeholder="Título del enlace" required>
        <input type="text" name="url" placeholder="URL del enlace" required>
        <button type="submit">Agregar</button>
    </form>

    <!-- Lista de enlaces -->
    <h2>Enlaces</h2>
    <ul>
        <% links.forEach(link=> { %>
            <li class="link">
                <a href="<%= link.url %>" target="_blank">
                    <strong>
                        <%= link.title %>
                    </strong>
                </a>
                <!-- Votar enlace -->
                <span id="vote-count-<%= link.id %>">Votos: <%= link.votes %></span>
                <button class="vote-link-btn" data-id="<%= link.id %>" data-topic-id="<%= topic.id %>">👍 Votar</button>

                <!-- Editar enlace -->
                <a href="/topics/<%= topic.id %>/links/<%= link.id %>/edit">✏️ Editar</a>

                <!-- Eliminar enlace -->
                <form action="/topics/<%= topic.id %>/links/<%= link.id %>?_method=DELETE" method="POST"
                    style="display:inline;">
                    <button type="submit">🗑️ Eliminar</button>
                </form>
            </li>
            <% }) %>
    </ul>

    <%- include('../partials/footer.ejs') %>