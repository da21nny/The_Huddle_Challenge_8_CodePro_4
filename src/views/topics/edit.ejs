<!-- Incluye el header con head, navbar y apertura del main -->
<%- include('../partials/header.ejs') %>

    <!-- Enlace para volver a la lista de topics -->
    <a href="/topics">← Volver a Temas</a>

    <h1>Editar Tema</h1>

    <!-- Formulario de edición: envía PUT mediante method-override -->
    <form action="/topics/<%= topic.id %>?_method=PUT" method="POST">
        <input type="text" name="title" value="<%= topic.title %>" placeholder="Título del tema" required>
        <input type="text" name="description" value="<%= topic.description %>" placeholder="Descripción del tema"
            required>
        <button type="submit">Actualizar</button>
    </form>

    <!-- Incluye el footer con cierre del main y scripts -->
    <%- include('../partials/footer.ejs') %>