<!DOCTYPE html>
<html>
<head>
    <title>Edit Link | Learn It, Love It</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <h1>Edit Link</h1>
        <a href="/topics/<%= topic.id %>" class="btn">Cancel</a>
    </div>
    
    <div class="card">
        <form action="/topics/<%= topic.id %>/links/<%= link.id %>?_method=PUT" method="POST">
            <div class="form-group">
                <label>URL</label>
                <input type="url" name="url" value="<%= link.url %>" required>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea name="description" rows="3" required><%= link.description %></textarea>
            </div>
            <button type="submit" class="btn">Update Link</button>
        </form>
    </div>
</body>
</html>