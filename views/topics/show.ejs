<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= topic.title %> | Learn It, Love It</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <header class="navbar">
        <div class="navbar__inner">
            <a href="/topics" class="navbar__brand">🎓 <span>Learn It, Love It</span></a>
            <nav class="navbar__nav">
                <a href="/topics" class="nav-link">← Volver a Temas</a>
            </nav>
        </div>
    </header>

    <main class="main-content">
        <div class="topic-header" style="margin-bottom: 2rem;">
            <h1 class="page-title"><%= topic.title %></h1>
            <p class="topic-description" style="font-size: 1.1rem; color: #555; margin-bottom: 1rem;"><%= topic.description %></p>
            <div class="topic-actions" style="display: flex; gap: 10px;">
                <a href="/topics/<%= topic.id %>/edit" class="btn btn--ghost">✏️ Editar</a>
                <form action="/topics/<%= topic.id %>?_method=DELETE" method="POST" class="inline-form">
                    <button type="submit" class="btn btn--ghost" style="color: red; border-color: red;">🗑️ Eliminar</button>
                </form>
            </div>
        </div>

        <section class="links-section">
            <div class="links-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                <h2>Enlaces Útiles</h2>
                <a href="/topics/<%= topic.id %>/links/new" class="btn btn--primary">🔗 Agregar Enlace</a>
            </div>
            
            <div id="links-container" class="links-list" style="display: flex; flex-direction: column; gap: 1rem;">
                <% if(topic.links && topic.links.length > 0) { %>
                    <% topic.links.forEach(link => { %>
                        <article class="card link-card" id="link-<%= link.id %>" style="display: flex; justify-content: space-between; align-items: center; padding: 1rem;">
                            <div class="card__content" style="flex: 1;">
                                <a href="<%= link.url %>" target="_blank" class="link-url" style="font-size: 1.2rem; font-weight: bold; color: var(--primary-color);"><%= link.url %></a>
                                <p class="card__desc" style="margin-top: 5px;"><%= link.description %></p>
                            </div>
                            <div class="card__footer" style="display: flex; gap: 15px; align-items: center;">
                                <button class="vote-btn vote-btn--link" data-topic-id="<%= topic.id %>" data-link-id="<%= link.id %>">
                                    👍 Votar <span id="count-link-<%= link.id %>" class="vote-count"><%= link.votes %></span>
                                </button>
                                <div class="action-buttons" style="display: flex; gap: 5px;">
                                    <a href="/topics/<%= topic.id %>/links/<%= link.id %>/edit" class="btn btn--ghost" style="padding: 0.5rem;">✏️</a>
                                    <form action="/topics/<%= topic.id %>/links/<%= link.id %>?_method=DELETE" method="POST" class="inline-form">
                                        <button type="submit" class="btn btn--ghost" style="color: red; padding: 0.5rem;">🗑️</button>
                                    </form>
                                </div>
                            </div>
                        </article>
                    <% }) %>
                <% } else { %>
                    <p class="empty-state" style="text-align: center; color: #888; padding: 2rem; background: white; border-radius: 8px;">No hay enlaces todavía. ¡Agrega uno!</p>
                <% } %>
            </div>
        </section>
    </main>

    <footer class="footer">
        <p>© 2026 Learn It, Love It Inc.</p>
    </footer>
    <script src="/js/main.js"></script>
</body>
</html>
