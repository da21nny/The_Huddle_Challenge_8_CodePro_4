<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= topic.title %> | Learn It, Love It</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <header class="navbar">
        <div class="navbar__inner">
            <a href="/topics" class="navbar__brand">🎓 Learn It, Love It</a>
            <nav class="navbar__nav">
                <a href="/topics" class="nav-link">← Volver</a>
            </nav>
        </div>
    </header>

    <main class="main-content">
        <h1 class="page-title"><%= topic.title %></h1>
        <p class="card__desc" style="margin-bottom:1.5rem;"><%= topic.description %></p>

        <div style="display:flex; gap:8px; margin-bottom:2rem;">
            <a href="/topics/<%= topic.id %>/edit" class="btn btn--ghost">✏️ Editar</a>
            <form action="/topics/<%= topic.id %>?_method=DELETE" method="POST" class="inline-form">
                <button type="submit" class="btn btn--ghost" style="color:var(--primary);">🗑️ Eliminar</button>
            </form>
        </div>

        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <h2 style="font-size:1.1rem;">Enlaces</h2>
            <a href="/topics/<%= topic.id %>/links/new" class="btn btn--primary">+ Enlace</a>
        </div>

        <div id="links-container" style="display:flex; flex-direction:column; gap:0.75rem;">
            <% if(topic.links && topic.links.length > 0) { %>
                <% topic.links.forEach(link => { %>
                    <div class="card" id="link-<%= link.id %>" style="flex-direction:row; align-items:center;">
                        <div style="flex:1;">
                            <a href="<%= link.url %>" target="_blank" style="color:var(--primary-h); font-weight:600;"><%= link.url %></a>
                            <p class="card__desc"><%= link.description %></p>
                        </div>
                        <div style="display:flex; align-items:center; gap:8px;">
                            <button class="vote-btn vote-btn--link" data-topic-id="<%= topic.id %>" data-link-id="<%= link.id %>">
                                👍 <span id="count-link-<%= link.id %>" class="vote-count"><%= link.votes %></span>
                            </button>
                            <a href="/topics/<%= topic.id %>/links/<%= link.id %>/edit" class="btn btn--ghost">✏️</a>
                            <form action="/topics/<%= topic.id %>/links/<%= link.id %>?_method=DELETE" method="POST" class="inline-form">
                                <button type="submit" class="btn btn--ghost" style="color:var(--primary);">🗑️</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-state">
                    <p>No hay enlaces. ¡Agrega uno!</p>
                </div>
            <% } %>
        </div>
    </main>

    <footer class="footer">
        <p>© 2026 Learn It, Love It Inc.</p>
    </footer>
    <script src="/js/main.js"></script>
</body>
</html>
