<!DOCTYPE html>
<html>
<head>
    <title><%= topic.title %> | Learn It, Love It</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/main.js"></script>
</head>
<body>
    <div class="header">
        <h1><%= topic.title %></h1>
        <a href="/topics" class="btn">Back to Topics</a>
    </div>
    
    <div class="card">
        <p><%= topic.description %></p>
        <div style="margin-top: 15px;">
            <a href="/topics/<%= topic.id %>/edit" class="btn">Edit Topic</a>
            <form action="/topics/<%= topic.id %>?_method=DELETE" method="POST">
                <button type="submit" class="btn btn-danger">Delete Topic</button>
            </form>
        </div>
    </div>

    <h3>Links</h3>
    <a href="/topics/<%= topic.id %>/links/new" class="btn">Add Link</a>
    
    <div id="links-list" style="margin-top: 20px;">
        <% if(topic.links.length === 0) { %>
            <p>No links yet. Add one!</p>
        <% } %>
        
        <% topic.links.forEach(link => { %>
            <div class="card link-card">
                <a href="<%= link.url %>" target="_blank" style="font-size: 18px; font-weight: bold;"><%= link.url %></a>
                <p><%= link.description %></p>
                <div class="votes-box">
                    <button class="btn" onclick="voteLink('<%= topic.id %>', '<%= link.id %>')">Upvote</button>
                    Votes: <span id="votes-link-<%= link.id %>" class="vote-count"><%= link.votes %></span>
                    
                    <span style="margin-left: 15px;">
                        <a href="/topics/<%= topic.id %>/links/<%= link.id %>/edit" class="btn">Edit</a>
                        <form action="/topics/<%= topic.id %>/links/<%= link.id %>?_method=DELETE" method="POST">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </span>
                </div>
            </div>
        <% }) %>
    </div>
</body>
</html>