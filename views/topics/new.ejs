<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nuevo Tema | Learn It, Love It</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <header class="navbar">
        <div class="navbar__inner">
            <a href="/topics" class="navbar__brand">🎓 <span>Learn It, Love It</span></a>
            <nav class="navbar__nav">
                <a href="/topics" class="nav-link">← Volver a Temas</a>
            </nav>
        </div>
    </header>

    <main class="main-content">
        <div class="form-container">
            <div class="form-card">
                <div class="form-card__header">
                    <h1 class="form-card__title">➕ Nuevo Tema</h1>
                    <p class="form-card__subtitle">Crea una nueva categoría de aprendizaje</p>
                </div>
                <form action="/topics" method="POST" class="form">
                    <div class="form-group">
                        <label for="title" class="form-label">Título</label>
                        <input type="text" id="title" name="title" class="form-input" placeholder="Ej: Aprender React" required />
                    </div>
                    <div class="form-group">
                        <label for="description" class="form-label">Descripción</label>
                        <textarea id="description" name="description" class="form-input form-textarea" placeholder="¿De qué trata este tema?" rows="4" required></textarea>
                    </div>
                    <div class="form-actions">
                        <a href="/topics" class="btn btn--ghost">Cancelar</a>
                        <button type="submit" class="btn btn--primary">Crear Tema</button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <footer class="footer">
        <p>© 2026 Learn It, Love It Inc.</p>
    </footer>
    <script src="/js/main.js"></script>
</body>
</html>
