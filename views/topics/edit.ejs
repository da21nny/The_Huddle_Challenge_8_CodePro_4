<%# Vista: formulario para editar un topic existente %>
  <!DOCTYPE html>
  <html lang="es">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar Tema | Learn It, Love It</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>

    <!-- Barra de navegación -->
    <header class="navbar">
      <div class="navbar__inner">
        <a href="/topics" class="navbar__brand">🎓 <span>Learn It, Love It</span></a>
        <nav class="navbar__nav">
          <a href="/topics/<%= topic.id %>" class="nav-link">← Volver al Tema</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <div class="form-container">
        <div class="form-card">

          <div class="form-card__header">
            <h1 class="form-card__title">✏️ Editar Tema</h1>
            <p class="form-card__subtitle">Actualiza la información de este tema</p>
          </div>

          <!-- Formulario de edición con method-override para PUT -->
          <form action="/topics/<%= topic.id %>?_method=PUT" method="POST" class="form">

            <div class="form-group">
              <label for="title" class="form-label">Título del tema</label>
              <input type="text" id="title" name="title" class="form-input" value="<%= topic.title %>" required
                maxlength="100" />
            </div>

            <div class="form-group">
              <label for="description" class="form-label">Descripción</label>
              <textarea id="description" name="description" class="form-input form-textarea" rows="4" required
                maxlength="500"><%= topic.description %></textarea>
            </div>

            <div class="form-actions">
              <a href="/topics/<%= topic.id %>" class="btn btn--ghost">Cancelar</a>
              <button type="submit" class="btn btn--primary">Guardar Cambios</button>
            </div>

          </form>

        </div>
      </div>
    </main>

    <footer class="footer">
      <p>© 2024 Learn It, Love It Inc.</p>
    </footer>

    <script src="/js/main.js"></script>
  </body>

  </html>