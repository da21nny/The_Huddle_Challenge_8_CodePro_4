<!DOCTYPE html>
<html>
<head>
    <title>Edit Topic | Learn It, Love It</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <h1>Edit Topic</h1>
        <a href="/topics/<%= topic.id %>" class="btn">Cancel</a>
    </div>
    
    <div class="card">
        <form action="/topics/<%= topic.id %>?_method=PUT" method="POST">
            <div class="form-group">
                <label>Title</label>
                <input type="text" name="title" value="<%= topic.title %>" required>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea name="description" rows="4" required><%= topic.description %></textarea>
            </div>
            <button type="submit" class="btn">Update Topic</button>
        </form>
    </div>
</body>
</html>